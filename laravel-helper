#!/bin/bash
set -e 

e() {
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    BLUE='\033[0;34m'
    NC='\033[0m'

    TXT_COLOR="${!2}"
    echo -e "${TXT_COLOR}$1${NC}"
}

help() {
    echo -e "$(e "### Help ###\n" "YELLOW")"

    echo -e "$(e "d - Target directory (eg: -d /opt/my-laravel)" "YELLOW")"
    echo -e "$(e "u - Update code using git pull (defaults to master branch)" "YELLOW")"
    echo -e "$(e "i - Install dependencies using composer" "YELLOW")"
    echo -e "$(e "c - Cache config files" "YELLOW")"
    echo -e "$(e "r - Fix folder permission / ownership" "YELLOW")"
    echo -e "$(e "o - Set ownership as owner:group for app files, like chown (eg: -o deploy:uapskm). Defaults to www-data:www-data. When set and run as root, code/build steps run as this owner" "YELLOW")"
    echo -e "$(e "f - Refresh laravel instance" "YELLOW")"
    echo -e "$(e "t - Output Laravel log file with specified line number (eg: -t 100 to output last 100 line)" "YELLOW")"
    echo -e "$(e "l - Output Laravel log file and append output as log file grow" "YELLOW")"
    echo -e "$(e "s - Restart a specific supervisor program (eg: -s laravel-worker)" "YELLOW")"
    echo -e "$(e "z - Restart Horizon (terminates so supervisor respawns it)" "YELLOW")"
    echo -e "$(e "p - Specify PHP version to use temporarily (eg: -p 8.1)" "YELLOW")"

    exit 0
}

check_deploy_dir() {
    if [[ -z "${DEPLOY_DIR}" ]]; then
        read -p "Use current folder $PWD? [y/n] " YN

        if [[ $YN == "y" || $YN == "Y" ]]; then
            DEPLOY_DIR="$PWD"
        else
            echo -e "\nExiting..."
            exit 1
        fi
    fi
}

switch_php_version() {
    if [[ -n "$PHP_VERSION" ]]; then
        echo -e "$(e "Switching to PHP $PHP_VERSION" "YELLOW")"
        PHP_PATH="/usr/bin/php$PHP_VERSION"
        if [[ ! -f "$PHP_PATH" ]]; then
            echo -e "$(e "Error: PHP version $PHP_VERSION is not installed on this system." "RED")"
            exit 1
        fi

        ORIGINAL_PHP=$(update-alternatives --query php | grep Value: | awk '{print $2}' | head -n 1)
        sudo update-alternatives --set php /usr/bin/php$PHP_VERSION
        PHP_CHANGED=true
    fi
}

revert_php_version() {
    if [[ "$PHP_CHANGED" == true ]]; then
        echo -e "$(e "Reverting to original PHP version" "YELLOW")"
        sudo update-alternatives --set php $ORIGINAL_PHP
    fi
}

# Run a code/build command as the target owner (from -o) when the script is
# invoked as root, so git/composer/artisan keep files owned by that user and use
# its credentials. When already running as the owner, runs the command directly.
# Privileged service actions (systemctl/supervisorctl/update-alternatives) are
# left as plain sudo so they still run as root.
as_owner() {
    if [[ ${#AS_OWNER[@]} -gt 0 ]]; then
        "${AS_OWNER[@]}" "$@"
    else
        "$@"
    fi
}

# Apply $OWNERSHIP (owner:group) to app files, skipping paths that don't exist
# so a missing dir doesn't abort the run under `set -e`. Runs without sudo:
# the deploying user owns the tree and only needs membership of the target group.
fix_ownership() {
    local targets=(app bootstrap config database lang public resources routes tests vendor artisan)
    local existing=()
    for t in "${targets[@]}"; do
        [[ -e "$t" ]] && existing+=("$t")
    done
    [[ ${#existing[@]} -gt 0 ]] && chown -R "$OWNERSHIP" "${existing[@]}"
}

update() {
    echo -e "$(e "Updating code in $DEPLOY_DIR\n" "YELLOW")"
    as_owner git checkout -- .
    as_owner git pull
    fix_ownership
}

install() {
    echo -e "$(e "Installing dependencies\n" "YELLOW")"
    as_owner composer install
    as_owner php artisan migrate
}

reset() {
    echo -e "$(e "Reset folder permissions\n" "YELLOW")"
    # Legacy www-data layout keeps 775; an explicit owner gets the hardened 2770
    # (group-writable, no access for others, setgid so new files inherit the group).
    local mode=2770
    [[ "${OWNERSHIP%%:*}" == "www-data" ]] && mode=775
    chgrp -R "${OWNERSHIP##*:}" storage/framework storage/logs bootstrap/cache && chmod -R "$mode" storage/framework storage/logs bootstrap/cache
    fix_ownership
}

refresh() {
    echo -e "$(e "Refresh laravel instance\n" "YELLOW")"
    as_owner composer dump-autoload
    as_owner php artisan cache:clear
    as_owner php artisan config:clear
    as_owner php artisan view:clear
    as_owner php artisan queue:restart

    PHP_VER=$(php -r 'echo PHP_MAJOR_VERSION.".".PHP_MINOR_VERSION;')
    FPM_SERVICE="php${PHP_VER}-fpm"
    if systemctl is-active --quiet "$FPM_SERVICE"; then
        echo -e "$(e "Restarting $FPM_SERVICE\n" "YELLOW")"
        sudo systemctl reload "$FPM_SERVICE"
    fi
}

cache_config() {
    as_owner php artisan config:cache
    as_owner php artisan route:cache
    as_owner php artisan view:cache
    as_owner php artisan event:cache
    as_owner php artisan filament:optimize || true
    as_owner php artisan horizon:terminate || true

    PHP_VER=$(php -r 'echo PHP_MAJOR_VERSION.".".PHP_MINOR_VERSION;')
    FPM_SERVICE="php${PHP_VER}-fpm"
    if systemctl is-active --quiet "$FPM_SERVICE"; then
        echo -e "$(e "Restarting $FPM_SERVICE\n" "YELLOW")"
        sudo systemctl restart "$FPM_SERVICE"
    fi
}

restart_supervisor() {
    local program="$1"
    [[ "$program" != *:* ]] && program="$program:*"
    echo -e "$(e "Restarting supervisor program: $program\n" "YELLOW")"
    sudo supervisorctl restart "$program"
}

restart_horizon() {
    echo -e "$(e "Restarting Horizon\n" "YELLOW")"
    as_owner php artisan horizon:terminate || true
}

tail_line() {
    echo -e "$(e "Laravel log\n" "YELLOW")"
    FILE="storage/logs/laravel-$(date +%Y-%m-%d).log"
    FILE2="storage/logs/laravel.log"
    if [ -f "$FILE" ]; then
        tail -n "$1" "$FILE"
    elif [ -f "$FILE2" ]; then
        tail -n "$1" $FILE2
    fi
}

tail_follow() {
    echo -e "$(e "Laravel log\n" "YELLOW")"
    FILE="storage/logs/laravel-$(date +%Y-%m-%d).log"
    FILE2="storage/logs/laravel.log"
    if [ -f "$FILE" ]; then
        tail -f "$FILE"
    elif [ -f "$FILE2" ]; then
        tail -f $FILE2
    fi
}

if [[ $# == 0 ]]; then
    help
fi


PHP_CHANGED=false
ACTIONS=()
# Ownership defaults to www-data:www-data for backwards compatibility. Setting it
# explicitly (via -o or the OWNERSHIP env var) is what opts in to running the
# code/build steps as that user when invoked as root.
OWNERSHIP_EXPLICIT=false
[[ -n "${OWNERSHIP:-}" ]] && OWNERSHIP_EXPLICIT=true
OWNERSHIP="${OWNERSHIP:-www-data:www-data}"
while getopts "hd:uicrft:ls:zp:o:" OPTION; do
    case $OPTION in
        h ) help ;;
        d ) DEPLOY_DIR="$OPTARG" ;;
        p ) PHP_VERSION="$OPTARG" ;;
        o ) OWNERSHIP="$OPTARG"; OWNERSHIP_EXPLICIT=true ;;
        u ) ACTIONS+=("update") ;;
        i ) ACTIONS+=("install") ;;
        c ) ACTIONS+=("cache_config") ;;
        r ) ACTIONS+=("reset") ;;
        f ) ACTIONS+=("refresh") ;;
        t ) TAIL_LINES="$OPTARG"; ACTIONS+=("tail_line $OPTARG") ;;
        l ) ACTIONS+=("tail_follow") ;;
        s ) ACTIONS+=("restart_supervisor $OPTARG") ;;
        z ) ACTIONS+=("restart_horizon") ;;
    esac
done

# When ownership was set explicitly and we are root for a different target user,
# drop code/build steps to that user via sudo (so files stay owned by them); leave
# service steps running as root. Without -o this stays empty -> legacy behavior.
OWNER="${OWNERSHIP%%:*}"
AS_OWNER=()
if [[ "$OWNERSHIP_EXPLICIT" == true && "$(id -u)" -eq 0 && "$(id -un)" != "$OWNER" ]]; then
    echo -e "$(e "Running as root; code steps will run as $OWNER" "YELLOW")"
    AS_OWNER=(sudo -u "$OWNER" -H --)
fi

check_deploy_dir
pushd $DEPLOY_DIR

switch_php_version

# Execute tasks in the order flags were provided
for ACTION in "${ACTIONS[@]}"; do
    $ACTION
done

popd
revert_php_version
